generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique @db.VarChar(50)
  password  String    @db.VarChar(255)
  role      String    @db.VarChar(20)
  balance   Decimal   @default(0.00) @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  shops     Shop[]
  orders    Order[]   @relation("UserOrders")
  
  @@map("users")
}

model Shop {
  id          Int       @id @default(autoincrement())
  merchantId  Int       @map("merchant_id")
  shopName    String    @db.VarChar(100) @map("shop_name")
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  merchant    User      @relation(fields: [merchantId], references: [id])
  products    Product[]
  orders      Order[]   @relation("ShopOrders")

  @@map("shops")
}

model Product {
  id          Int       @id @default(autoincrement())
  shopId      Int       @map("shop_id")
  productName String    @db.VarChar(100) @map("product_name")
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2)
  imageUrl    String?   @db.VarChar(255) @map("image_url")
  status      String    @default("active") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")
  shop        Shop      @relation(fields: [shopId], references: [id])
  orders      Order[]

  @@map("products")
}

model Order {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  productId  Int      @map("product_id")
  shopId     Int      @map("shop_id")
  quantity   Int      @default(1)
  totalPrice Decimal  @db.Decimal(12, 2) @map("total_price")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation("UserOrders", fields: [userId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  shop       Shop     @relation("ShopOrders", fields: [shopId], references: [id])

  @@map("orders")
}
